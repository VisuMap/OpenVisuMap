#MenuLabels D-Sorting D-Embedding D-Clustering ActiveGenes ActiveCells SaveData SaveHeatmap SaveDsHm ShowMean Info
vv.Import('HeatmapHelp.pyn')

def HeatMapMain(menu):
	match menu:
		case 'D-Sorting':
			DualSorting(pp, pRow=(1000, 2000, 0.05, 2.0, 1.0), pColumn=(50000, 2000, 0.05, 2.0, 1.0))
		case 'D-Embedding':
			#vv.RunScript('DualEmbedding.js', pp)
			DualEmbedding(pp, pRow=(1000, 2000, 0.05, 2.0, 1.0), pColumn=(50000, 2000, 0.05, 1.5, 1.0))
		case 'D-Clustering':
			#vv.RunScript('DualClustering.js', pp)
			DualClustering(pp, pRow=(0, 40, 15, 2.0, 30), pColumn=(0, 40, 15, 3.0, 30) )
		case 'ActiveGenes':
			#vv.RunScript('ShowActiveGenes.js', pp)
			ShowActiveGenes(pp)
		case 'ActiveCells':
			#vv.RunScript('ShowActiveCells.js', pp)
			ShowActiveCells(pp)
		case 'SaveData':
			#vv.RunScript('SaveDataset.js', pp)
			SaveHeatmapComplex(pp)
		case 'SaveHeatmap':
			#vv.RunScript('SaveSortedHeatmap.js', pp)
			SaveSortedHeatmap(pp)
		case 'SaveDsHm':
			#vv.RunScript('!vv.Import('AtlasHelp.js');SaveDsHm(pp);', pp)
			SaveDsHm(pp)
		case 'ShowMean':
			#vv.RunScript('ShowMeanVector.js', pp)
			ShowHeatmapMean(pp)
		case 'Info':
			ShowInfo(pp)

HeatMapMain(vv.EventSource.Item)

