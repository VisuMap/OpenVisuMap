#MenuLabels Info 'Capture Coloring' ShowGraph
vv.Import('Common.pyn')
vv.Import('HeatmapHelp.pyn')

match vv.EventSource.Item:
	case 'Info':
		ShowInfo(pp)
	case 'Capture Coloring':  
		# copy the cluster coloring to the linked heatmap's rows or columns depending on the map type.
		CopyColoring2Heatmap(pp)
	case 'ShowGraph':
		vv.Import('GraphHelp.pyn')
		info = MapInfo(pp)
		cntThr = 0.175 if info.MapType=='Cell Clusters' else 0.15
		ShowClusterGraph(pp, cntThr)
